CXX = cl.exe
CXXFLAGS = /W4 /DEBUG /EHsc /std:c++20 /I.
WINLIBS = ntdll.lib

EXAMPLE_NAME = simple_import

GENERATED = generated.h src/generated.rs

RUSTLIB_PATH = ../../target/release/

RUSTLIB = example_$(EXAMPLE_NAME).lib

a.exe : main.cpp src/lib.rs $(GENERATED) zngur.h $(RUSTLIB_PATH)/$(RUSTLIB)
	$(CXX) $(CXXFLAGS) main.cpp foo.cpp bar.cpp /Fe:a.exe /link $(WINLIBS) $(RUSTLIB) /LIBPATH:$(RUSTLIB_PATH)

$(RUSTLIB_PATH)/$(RUSTLIB) :
	cargo build --release

$(GENERATED) : main.zng
	cd ../../zngur-cli && cargo run g ../examples/$(EXAMPLE_NAME)/main.zng

zngur.h :
	cd ..\..\zngur-cli && cargo run -- make-zng-header --panic-to-exception ..\examples\$(EXAMPLE_NAME)\zngur.h


clean :
	- del /f /q generated.h generated.cpp zngur.h src\generated.rs a.exe main.obj foo.obj bar.obj actual_output.txt 2>nul
